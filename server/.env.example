PORT=8080
DATABASE_URL=postgres://app:app@localhost:5432/app?sslmode=disable
JWT_SECRET=dev-secret-change-me
# Comma-separated list of allowed CORS origins for the web client
CORS_ORIGINS=http://localhost:8081,http://localhost:19006
# LLM provider for the generation pipeline: mock (default, no keys needed),
# ollama (local daemon); anthropic and openai are recognized but not yet implemented.
LLM_PROVIDER=mock
# Model name, required for ollama (e.g. gemma4:26b).
LLM_MODEL=
# Base URL override; ollama defaults to http://localhost:11434 when blank.
LLM_BASE_URL=
# Text-to-speech via Piper (piper1-gpl) is OPTIONAL and zero-config: run
# `make tts-setup` and the server auto-discovers the voice in server/voices and
# the piper command. Without it, the web client uses the browser's voice.
# These overrides are only needed for a non-default setup:
#   VOICES_DIR  — where to look for *.onnx voices (default: voices)
#   PIPER_VOICE — explicit path to a .onnx model (overrides auto-discovery)
#   PIPER_BIN   — "auto" (default) or a command like "python3 -m piper"
# VOICES_DIR=voices
# PIPER_VOICE=
# PIPER_BIN=auto
